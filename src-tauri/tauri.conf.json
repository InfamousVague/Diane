{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Diane",
  "version": "0.5.2",
  "identifier": "com.mattssoftware.diane",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5178",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Diane",
        "width": 350,
        "height": 800,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "0948896DC970503ADEF5B5070E0BB3E9D9047757"
    },
    "resources": {
      "../public/assets/default-tape.wav": "default-tape.wav"
    }
  }
}
